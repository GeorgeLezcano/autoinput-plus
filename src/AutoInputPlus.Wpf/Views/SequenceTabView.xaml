<UserControl x:Class="AutoInputPlus.Wpf.Views.SequenceTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F8">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Sequence"
                       FontSize="24"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT -->
            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="#D9E0E7"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Saved Sequences"
                               FontWeight="SemiBold"/>

                    <ListBox Grid.Row="2"/>

                    <!-- Buttons FULL WIDTH -->
                    <StackPanel Grid.Row="4">
                        <Button Content="New"
                                Height="32"
                                Margin="0,0,0,6"
                                HorizontalContentAlignment="Center"/>

                        <Button Content="Rename"
                                Height="32"
                                Margin="0,0,0,6"
                                HorizontalContentAlignment="Center"/>

                        <Button Content="Delete"
                                Height="32"
                                HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT -->
            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="#D9E0E7"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="16">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Steps"
                               FontWeight="SemiBold"/>

                    <DataGrid Grid.Row="2"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Width="50"/>

                            <DataGridTextColumn Header="Target"
                                                Width="*"/>

                            <DataGridCheckBoxColumn Header="Hold"
                                                    Width="70"/>

                            <DataGridTextColumn Header="Duration"
                                                Width="120"/>

                            <DataGridTextColumn Header="Delay"
                                                Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal">
                        <Button Content="Add"
                                Width="80"
                                Height="32"
                                Margin="0,0,8,0"/>
                        <Button Content="Remove"
                                Width="80"
                                Height="32"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
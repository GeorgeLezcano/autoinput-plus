<UserControl x:Class="AutoInputPlus.Wpf.Views.SequenceTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Sequence"
                       FontSize="24"
                       FontWeight="SemiBold"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Style="{DynamicResource CardBorderStyle}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Saved Sequences"
                               FontWeight="SemiBold"/>

                    <ListBox x:Name="SequenceListBox"
                             Grid.Row="2"
                             DisplayMemberPath="Name"
                             SelectionChanged="SequenceListBox_SelectionChanged"/>

                    <StackPanel Grid.Row="4">
                        <Button Content="New"
                                Height="32"
                                Margin="0,0,0,6"
                                HorizontalContentAlignment="Center"
                                Click="NewSequenceButton_Click"/>

                        <Button Content="Rename"
                                Height="32"
                                Margin="0,0,0,6"
                                HorizontalContentAlignment="Center"
                                Click="RenameSequenceButton_Click"/>

                        <Button Content="Delete"
                                Height="32"
                                HorizontalContentAlignment="Center"
                                Click="DeleteSequenceButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="16"
                    Style="{DynamicResource CardBorderStyle}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Steps"
                               FontWeight="SemiBold"/>

                    <DataGrid x:Name="StepsDataGrid"
                              Grid.Row="2"
                              AutoGenerateColumns="False"
                              HeadersVisibility="Column"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              RowHeaderWidth="0"
                              LoadingRow="StepsDataGrid_LoadingRow">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#"
                                                Width="50"
                                                IsReadOnly="True"
                                                Binding="{Binding StepNumber}"/>

                            <DataGridTemplateColumn Header="Target"
                                                    Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding TargetDisplay}"
                                                HorizontalContentAlignment="Center"
                                                Click="StepTargetButton_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Hold"
                                                    Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  IsChecked="{Binding Step.IsHold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Checked="StepHoldCheckBox_Changed"
                                                  Unchecked="StepHoldCheckBox_Changed"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Hold Duration (ms)"
                                                    Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Step.DurationMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PreviewTextInput="NonNegativeIntegerTextBox_PreviewTextInput"
                                                 TextChanged="StepDurationTextBox_TextChanged"
                                                 PreviewMouseLeftButtonDown="EditableCellControl_PreviewMouseLeftButtonDown"
                                                 IsEnabled="{Binding Step.IsHold}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Delay After (ms)"
                                                    Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Step.DelayAfterMilliseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 PreviewTextInput="NonNegativeIntegerTextBox_PreviewTextInput"
                                                 TextChanged="StepDelayAfterTextBox_TextChanged"
                                                 PreviewMouseLeftButtonDown="EditableCellControl_PreviewMouseLeftButtonDown"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="4"
                                Orientation="Horizontal">
                        <Button Content="Add"
                                Width="80"
                                Height="32"
                                Margin="0,0,8,0"
                                Click="AddStepButton_Click"/>
                        <Button Content="Remove"
                                Width="80"
                                Height="32"
                                Click="RemoveStepButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
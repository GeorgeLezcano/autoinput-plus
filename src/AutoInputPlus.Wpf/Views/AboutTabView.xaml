<UserControl x:Class="AutoInputPlus.Wpf.Views.AboutTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="About AutoInput Plus"
                       FontSize="24"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Basic application information."
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource TextBrushSecondary}"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="16"
                MaxWidth="700"
                HorizontalAlignment="Left"
                Style="{DynamicResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Application"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           x:Name="ProductTextBlock"
                           Text="AutoInput Plus"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Version"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           x:Name="VersionTextBlock"
                           Text="-"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="Author"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           x:Name="AuthorTextBlock"
                           Text="-"/>

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Text="Repository"
                           FontWeight="SemiBold"/>

                <Grid Grid.Row="6"
                      Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               x:Name="RepositoryTextBlock"
                               Text="-"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"/>

                    <Button Grid.Column="2"
                            x:Name="CopyToClipboardButton"
                            Content="&#xE8C8;"
                            Width="32"
                            Height="32"
                            Padding="0"
                            VerticalAlignment="Top"
                            FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                            ToolTip="Copy repository URL"
                            Click="CopyToClipboardButton_Click"/>
                </Grid>

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Text="Description"
                           FontWeight="SemiBold"/>
                <TextBlock Grid.Row="8"
                           Grid.Column="1"
                           Text="A desktop automation tool for repeated single-input and profile-based sequence execution."
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
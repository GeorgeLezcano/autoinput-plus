<UserControl x:Class="AutoInputPlus.Wpf.Views.SettingsTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppBackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Settings"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Configure how the current profile behaves."
                           Margin="0,6,0,0"
                           Foreground="{DynamicResource TextBrushSecondary}"/>
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="16"
                    Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Run Configuration"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Border Grid.Row="2"
                            Padding="12"
                            Style="{DynamicResource InnerPanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Mode"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="SingleInputModeRadioButton"
                                             GroupName="ExecutionMode"
                                             Content="Single Input"
                                             IsChecked="True"
                                             Margin="0,0,20,0" 
                                             Checked="SingleInputModeRadioButton_Checked"/>
                                <RadioButton x:Name="SequenceModeRadioButton"
                                             GroupName="ExecutionMode"
                                             Content="Sequence Mode" 
                                             Checked="SequenceModeRadioButton_Checked"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="4"
                            Padding="12"
                            Style="{DynamicResource InnerPanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="Key Settings"
                                       FontWeight="SemiBold"/>

                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Start / Stop Hotkey"
                                               Margin="0,0,0,6"/>
                                    <Button x:Name="CaptureHotkeyButton"
                                            Height="34"
                                            Width="120"
                                            Content="F8"
                                            HorizontalContentAlignment="Center" 
                                            Click="CaptureHotkeyButton_Click"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Target Key / Button"
                                               Margin="0,0,0,6"/>
                                    <Button x:Name="CaptureTargetKeyButton"
                                            Height="34"
                                            Width="120"
                                            Content="Left Click"
                                            HorizontalContentAlignment="Center" 
                                            Click="CaptureTargetKeyButton_Click"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="6"
                            Padding="12"
                            Style="{DynamicResource InnerPanelBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Padding="12"
                                    Style="{DynamicResource InsetCardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="12"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Input Behavior"
                                               FontWeight="SemiBold"/>

                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="Interval (ms)"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="IntervalTextBox"
                                                 Height="34"
                                                 Width="120"
                                                 Text="100"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center" 
                                                 TextChanged="IntervalTextBox_TextChanged"/>
                                    </StackPanel>

                                    <CheckBox Grid.Row="4"
                                              x:Name="HoldCheckBox" 
                                              Checked="HoldCheckBox_Checked"
                                              Unchecked="HoldCheckBox_Unchecked">
                                        <TextBlock Text="Hold target instead of repeating input"
                                                   TextWrapping="Wrap"/>
                                    </CheckBox>
                                </Grid>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="12"
                                    Style="{DynamicResource InsetCardBorderStyle}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="10"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Text="Run Behavior"
                                               FontWeight="SemiBold"/>

                                    <RadioButton Grid.Row="2"
                                                 x:Name="RunUntilStopRadioButton"
                                                 GroupName="RunMode"
                                                 Content="Run until manually stopped"
                                                 IsChecked="True" 
                                                 Checked="RunUntilStopRadioButton_Checked"/>

                                    <RadioButton Grid.Row="4"
                                                 x:Name="RunForSetCountRadioButton"
                                                 GroupName="RunMode"
                                                 Content="Run for set count" 
                                                 Checked="RunForSetCountRadioButton_Checked"/>

                                    <StackPanel Grid.Row="6"
                                                Margin="18,0,0,0">
                                        <TextBlock Text="Count"
                                                   Margin="0,0,0,6"/>
                                        <TextBox x:Name="RunCountTextBox"
                                                 Height="34"
                                                 Width="120"
                                                 Text="100"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center" 
                                                 TextChanged="RunCountTextBox_TextChanged"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Padding="16"
                    Style="{DynamicResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Schedule"
                               FontSize="18"
                               FontWeight="SemiBold"/>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <CheckBox x:Name="ScheduleStartEnabledCheckBox"
                                      Content="Use scheduled start"
                                      Margin="0,0,0,8" 
                                      Checked="ScheduleStartEnabledCheckBox_Checked"
                                      Unchecked="ScheduleStartEnabledCheckBox_Unchecked"/>
                            <TextBlock Text="Start Date / Time"
                                       Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePicker x:Name="ScheduleStartDatePicker"
                                            Grid.Column="0"
                                            Height="34"
                                            HorizontalContentAlignment="Center"/>

                                <Border Grid.Column="2"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBox x:Name="ScheduleStartHourTextBox"
                                                 Width="32"
                                                 MaxLength="2"
                                                 Text="00"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text=":"
                                                   Margin="6,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <TextBox x:Name="ScheduleStartMinuteTextBox"
                                                 Width="32"
                                                 MaxLength="2"
                                                 Text="00"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text=":"
                                                   Margin="6,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <TextBox x:Name="ScheduleStartSecondTextBox"
                                                 Width="32"
                                                 MaxLength="2"
                                                 Text="00"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <CheckBox x:Name="ScheduleStopEnabledCheckBox"
                                      Content="Use scheduled stop"
                                      Margin="0,0,0,8" 
                                      Checked="ScheduleStopEnabledCheckBox_Checked"
                                      Unchecked="ScheduleStopEnabledCheckBox_Uchecked"/>
                            <TextBlock Text="Stop Date / Time"
                                       Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <DatePicker x:Name="ScheduleStopDatePicker"
                                            Grid.Column="0"
                                            Height="34"
                                            HorizontalContentAlignment="Center"/>

                                <Border Grid.Column="2"
                                        Background="{DynamicResource SurfaceBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8,6">
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBox x:Name="ScheduleStopHourTextBox"
                                                 Width="32"
                                                 MaxLength="2"
                                                 Text="00"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text=":"
                                                   Margin="6,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <TextBox x:Name="ScheduleStopMinuteTextBox"
                                                 Width="32"
                                                 MaxLength="2"
                                                 Text="00"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBlock Text=":"
                                                   Margin="6,0"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <TextBox x:Name="ScheduleStopSecondTextBox"
                                                 Width="32"
                                                 MaxLength="2"
                                                 Text="00"
                                                 TextAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
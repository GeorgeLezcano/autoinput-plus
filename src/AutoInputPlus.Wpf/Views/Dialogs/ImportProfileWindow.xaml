<Window x:Class="AutoInputPlus.Wpf.Views.Dialogs.ImportProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Profile"
        Width="700"
        Height="450"
        MinWidth="560"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Import Profile"
                       FontSize="22"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Paste an encoded profile string below to import."
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource TextBrushSecondary}"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="12"
                Style="{DynamicResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Encoded Profile String"
                           FontWeight="SemiBold"/>

                <TextBox Grid.Row="2"
                         x:Name="ImportTextBox"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         AcceptsReturn="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         MinHeight="200"
                         TextChanged="ImportTextBox_TextChanged"/>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4"
                   x:Name="ValidationTextBlock"
                   Text=""
                   Visibility="Collapsed"
                   TextWrapping="Wrap"
                   Foreground="IndianRed"/>

        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    x:Name="ImportButton"
                    Width="110"
                    Height="34"
                    IsDefault="True"
                    Click="ImportButton_Click"
                    Content="Import"/>

            <Button Grid.Column="3"
                    Width="100"
                    Height="34"
                    IsCancel="True"
                    Click="CancelButton_Click"
                    Content="Cancel"/>
        </Grid>
    </Grid>
</Window>
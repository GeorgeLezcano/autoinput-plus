<Window x:Class="AutoInputPlus.Wpf.Views.Dialogs.ExportProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Profile"
        Width="700"
        Height="420"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Export Profile"
                       FontSize="22"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Copy this encoded profile string to share."
                       Margin="0,6,0,0"
                       Foreground="{DynamicResource TextBrushSecondary}"/>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="12"
                Style="{DynamicResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Encoded Profile String"
                           FontWeight="SemiBold"/>

                <TextBox Grid.Row="2"
                         x:Name="ExportTextBox"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         AcceptsReturn="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         MinHeight="180"/>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    x:Name="CopyButton"
                    Width="110"
                    Height="34"
                    Click="CopyButton_Click">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center">
                    <TextBlock x:Name="CopyButtonIconTextBlock"
                               Text="&#xE8C8;"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                    <TextBlock x:Name="CopyButtonLabelTextBlock"
                               Text="Copy"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="3"
                    Width="100"
                    Height="34"
                    IsCancel="True"
                    Click="CloseButton_Click"
                    Content="Close"/>
        </Grid>
    </Grid>
</Window>
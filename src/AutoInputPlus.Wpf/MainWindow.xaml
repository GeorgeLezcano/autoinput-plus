<Window x:Class="AutoInputPlus.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AutoInputPlus.Wpf.Views"
        Title="AutoInput Plus"
        Width="1160"
        Height="780"
        MinWidth="1100"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Padding="12,8"
              Background="{DynamicResource SurfaceBrush}"
              Foreground="{DynamicResource TextBrushPrimary}">

            <MenuItem Header="_Tools">
                <MenuItem Header="_Export Active Profile"
                          Click="ExportProfile_Click">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>

                <MenuItem Header="_Import Profile"
                          Click="ImportProfile_Click">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>

                <Separator/>

                <MenuItem Header="_Open Data Folder"
                          Click="OpenDataFolderMenuItem_Click">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Themes">
                <MenuItem x:Name="LightBlueThemeMenuItem"
                          Header="_Light Blue"
                          IsCheckable="True"
                          Click="LightBlueThemeMenuItem_Click">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>

                <MenuItem x:Name="DarkBlueThemeMenuItem"
                          Header="_Dark Blue (Unfinished)"
                          IsCheckable="True"
                          Click="DarkBlueThemeMenuItem_Click">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Margin="12,12,12,0"
                Padding="12"
                Style="{DynamicResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="12,10"
                        VerticalAlignment="Center"
                        Style="{DynamicResource InnerPanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Engine"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <CheckBox x:Name="EngineEnabledCheckBox"
                                      VerticalAlignment="Center"
                                      Checked="EngineEnabledCheckBox_Checked"
                                      Unchecked="EngineEnabledCheckBox_Unchecked">
                                <TextBlock Text="Enabled"
                                           FontWeight="SemiBold"/>
                            </CheckBox>

                            <CheckBox x:Name="RunOnStartupCheckBox"
                                      Margin="16,0,0,0"
                                      VerticalAlignment="Center"
                                      Checked="RunOnStartupCheckBox_Checked"
                                      Unchecked="RunOnStartupCheckBox_Unchecked">
                                <TextBlock Text="Run on Windows startup"
                                           FontWeight="SemiBold"/>
                            </CheckBox>
                        </StackPanel>

                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Status:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextBrushSecondary}"/>

                            <Border x:Name="EngineStatusBadge"
                                    CornerRadius="12"
                                    Background="{DynamicResource StatusNeutralBrush}"
                                    Padding="10,4"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="EngineStatusTextBlock"
                                           Text="Unavailable"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource StatusNeutralTextBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="12,10"
                        VerticalAlignment="Center"
                        Style="{DynamicResource InnerPanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Profile"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="ProfilesComboBox"
                                  Grid.Column="2"
                                  Height="32"
                                  VerticalAlignment="Center"
                                  HorizontalContentAlignment="Center"
                                  SelectionChanged="ProfilesComboBox_SelectionChanged"/>

                        <Button x:Name="NewProfileButton"
                                Grid.Column="4"
                                Content="New"
                                Width="72"
                                HorizontalContentAlignment="Center"
                                Click="NewProfileButton_Click"
                                Grid.ColumnSpan="2"
                                Margin="0,0,8,0"/>

                        <Button x:Name="RenameProfileButton"
                                Grid.Column="6"
                                Content="Rename"
                                Width="82"
                                Height="32"
                                HorizontalContentAlignment="Center"
                                Click="RenameProfileButton_Click"/>

                        <Button x:Name="DeleteProfileButton"
                                Grid.Column="8"
                                Content="Delete"
                                Width="78"
                                Height="32"
                                HorizontalContentAlignment="Center"
                                Click="DeleteProfileButton_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Margin="12">
            <TabControl x:Name="RootTabControl">

                <TabItem x:Name="SettingsTab"
                         Header="Settings">
                    <views:SettingsTabView x:Name="SettingsTabViewContent"/>
                </TabItem>

                <TabItem x:Name="SequenceTab"
                         Header="Sequence">
                    <views:SequenceTabView x:Name="SequenceTabViewContent"/>
                </TabItem>

                <TabItem x:Name="AboutTab"
                         Header="About">
                    <views:AboutTabView/>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>
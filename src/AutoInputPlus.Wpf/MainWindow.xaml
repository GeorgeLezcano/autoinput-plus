<Window x:Class="AutoInputPlus.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AutoInputPlus.Wpf.Views"
        Title="AutoInput Plus"
        Height="800"
        Width="1100"
        MinHeight="640"
        MinWidth="980"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}">

    <DockPanel>

        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource SurfaceBrush}"
              BorderBrush="{DynamicResource BorderBrushSoft}"
              BorderThickness="0,0,0,1">

            <MenuItem Header="_Tools">
                <MenuItem Header="Import Profile...">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>

                <MenuItem Header="Export Profile...">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>

                <Separator/>

                <MenuItem Header="Open Data Folder">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>
            </MenuItem>

            <MenuItem Header="_Themes">
                <MenuItem x:Name="LightBlueThemeMenuItem"
                          Header="_Light Blue"
                          IsCheckable="True"
                          Click="LightBlueThemeMenuItem_Click">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>

                <MenuItem x:Name="DarkBlueThemeMenuItem"
                          Header="_Dark Blue"
                          IsCheckable="True"
                          Click="DarkBlueThemeMenuItem_Click">
                    <MenuItem.Style>
                        <Style TargetType="MenuItem">
                            <Setter Property="Background"
                                    Value="{DynamicResource MenuSubItemBackgroundBrush}"/>
                            <Setter Property="Foreground"
                                    Value="{DynamicResource MenuSubItemForegroundBrush}"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{DynamicResource MenuSubItemHoverBackgroundBrush}"/>
                                    <Setter Property="Foreground"
                                            Value="{DynamicResource MenuSubItemHoverForegroundBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </MenuItem.Style>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Margin="12,12,12,0"
                Padding="12"
                Style="{DynamicResource CardBorderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Padding="12,10"
                        VerticalAlignment="Center"
                        Style="{DynamicResource InnerPanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Engine"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <CheckBox x:Name="EngineEnabledCheckBox"
                                  Grid.Column="2"
                                  VerticalAlignment="Center">
                            <TextBlock Text="Enabled"
                                       FontWeight="SemiBold"/>
                        </CheckBox>

                        <StackPanel Grid.Column="4"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Status:"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="{DynamicResource TextBrushSecondary}"/>
                            <Border CornerRadius="12"
                                    Background="{DynamicResource StatusNeutralBrush}"
                                    Padding="10,4"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="EngineStatusTextBlock"
                                           Text="Disabled"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource StatusNeutralTextBrush}"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Padding="12,10"
                        VerticalAlignment="Center"
                        Style="{DynamicResource InnerPanelBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="Profile"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <ComboBox x:Name="ProfilesComboBox"
                                  Grid.Column="2"
                                  Height="32"
                                  VerticalAlignment="Center"
                                  SelectedIndex="0"
                                  HorizontalContentAlignment="Center">
                            <ComboBoxItem Content="Default Profile"/>
                        </ComboBox>

                        <Button x:Name="NewProfileButton"
                                Grid.Column="4"
                                Content="New"
                                Width="72"
                                Height="32"
                                HorizontalContentAlignment="Center"/>

                        <Button x:Name="RenameProfileButton"
                                Grid.Column="6"
                                Content="Rename"
                                Width="82"
                                Height="32"
                                HorizontalContentAlignment="Center"/>

                        <Button x:Name="DeleteProfileButton"
                                Grid.Column="8"
                                Content="Delete"
                                Width="78"
                                Height="32"
                                HorizontalContentAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Margin="12">
            <TabControl x:Name="RootTabControl">

                <TabItem x:Name="SettingsTab"
                         Header="Settings">
                    <views:SettingsTabView/>
                </TabItem>

                <TabItem x:Name="SequenceTab"
                         Header="Sequence">
                    <views:SequenceTabView/>
                </TabItem>

                <TabItem x:Name="AboutTab"
                         Header="About">
                    <views:AboutTabView/>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>